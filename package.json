{
  "name": "nightpool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "stack": "docker compose up -d",
    "stack:down": "docker compose down",
    "compact": "pnpm --filter @nightpool/contract compact",
    "build:contract": "pnpm --filter @nightpool/contract build",
    "backend": "pnpm --filter @nightpool/backend dev",
    "db:push": "pnpm --filter @nightpool/backend db:push",
    "dev": "pnpm --filter @nightpool/frontend dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "2.5.1",
    "@midnight-ntwrk/compact-runtime": "0.16.0",
    "@midnight-ntwrk/dapp-connector-api": "4.0.1",
    "@midnight-ntwrk/ledger-v8": "8.1.0",
    "@midnight-ntwrk/midnight-js": "4.1.0",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "4.1.0",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "4.1.0",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "4.1.0",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "4.1.0",
    "@midnight-ntwrk/onchain-runtime-v3": "3.0.0",
    "@midnight-ntwrk/wallet-sdk": "1.0.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  },
  "pnpm": {
    "overrides": {
      "@midnight-ntwrk/ledger-v8": "8.1.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "classic-level",
      "msgpackr-extract"
    ]
  }
}
