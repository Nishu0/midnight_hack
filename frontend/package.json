{
  "name": "@nightpool/frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm copy-keys && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "copy-keys": "mkdir -p ./public/midnight/nightpool/keys ./public/midnight/nightpool/zkir && cp -r ../contract/src/managed/nightpool/keys/* ./public/midnight/nightpool/keys/ && cp -r ../contract/src/managed/nightpool/zkir/* ./public/midnight/nightpool/zkir/"
  },
  "dependencies": {
    "@nightpool/contract": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-plugin-wasm": "^3.4.1"
  }
}
