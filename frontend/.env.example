# network id hinted to the wallet on connect. use "undeployed" for the local
# docker stack, or match whatever network your Lace wallet is on (e.g. "testnet").
# indexer / proof server / node uris are read from the wallet after connecting.
VITE_NETWORK_ID=undeployed

# optional: proof server fallback if the wallet doesn't report one
VITE_PROOF_SERVER_URI=http://127.0.0.1:6300
