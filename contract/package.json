{
  "name": "@nightpool/contract",
  "version": "0.1.0",
  "description": "NightPool — sealed-bid batch-auction DEX contract (Compact) for Midnight",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "compact": "compact compile +0.31.0 src/nightpool.compact src/managed/nightpool",
    "build": "rm -rf dist && tsc --project tsconfig.build.json && cp -Rf ./src/managed ./dist/managed && cp ./src/nightpool.compact ./dist",
    "test:compile": "pnpm compact && pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "~5.8.3"
  },
  "peerDependencies": {
    "@midnight-ntwrk/compact-runtime": "*"
  }
}
